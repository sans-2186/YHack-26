{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal.local/schemas/analyze_response.proposed.json",
  "title": "AnalyzeResponse (proposed v2)",
  "type": "object",
  "required": [
    "analysis_id",
    "company",
    "financials",
    "news",
    "scores",
    "recommendation",
    "meta"
  ],
  "properties": {
    "analysis_id": { "type": "string" },
    "company": {
      "type": "object",
      "required": ["ticker", "name"],
      "properties": {
        "ticker": { "type": "string" },
        "name": { "type": "string" },
        "exchange": { "type": ["string", "null"] },
        "sector": { "type": ["string", "null"] }
      }
    },
    "financials": {
      "type": "object",
      "required": ["summary", "metrics"],
      "properties": {
        "summary": { "type": "string" },
        "metrics": {
          "type": "object",
          "properties": {
            "market_cap_usd": { "type": ["number", "null"] },
            "pe_ratio": { "type": ["number", "null"] },
            "revenue_ttm_usd": { "type": ["number", "null"] },
            "debt_to_equity": { "type": ["number", "null"] }
          }
        },
        "as_of": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "news": {
      "type": "object",
      "required": ["items", "sentiment", "bias"],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title"],
            "properties": {
              "title": { "type": "string" },
              "url": { "type": ["string", "null"] },
              "source": { "type": ["string", "null"] },
              "published_at": { "type": ["string", "null"], "format": "date-time" },
              "outlet_leaning": {
                "type": ["string", "null"],
                "description": "optional: left | center | right | unknown"
              },
              "event_tags": {
                "type": "array",
                "items": { "type": "string" }
              },
              "political_risk_tags": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "sentiment": {
          "type": "object",
          "required": ["score_0_100", "label", "spread", "confidence"],
          "properties": {
            "score_0_100": { "type": "number", "minimum": 0, "maximum": 100 },
            "label": { "type": "string" },
            "spread": { "type": "number", "description": "dispersion of headline-level polarity" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "aggregate_score_legacy": {
              "type": "number",
              "description": "optional: keep -1..1 for backward compat"
            }
          }
        },
        "bias": {
          "type": "object",
          "properties": {
            "label": { "type": "string" },
            "notes": { "type": ["string", "null"] },
            "distinct_sources": { "type": "integer" }
          }
        }
      }
    },
    "scores": {
      "type": "object",
      "required": [
        "financial",
        "sentiment",
        "bias_risk",
        "political_risk"
      ],
      "properties": {
        "financial": { "$ref": "#/$defs/componentScore" },
        "sentiment": { "$ref": "#/$defs/componentScore" },
        "bias_risk": { "$ref": "#/$defs/componentScore" },
        "political_risk": { "$ref": "#/$defs/componentScore" }
      }
    },
    "recommendation": {
      "type": "object",
      "required": [
        "label",
        "confidence",
        "summary_reasoning",
        "score_breakdown"
      ],
      "properties": {
        "label": {
          "type": "string",
          "enum": ["Invest", "Risky", "Avoid"]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "summary_reasoning": { "type": "string" },
        "bull_case": { "type": "string" },
        "bear_case": { "type": "string" },
        "key_risks": { "type": "array", "items": { "type": "string" } },
        "key_drivers": { "type": "array", "items": { "type": "string" } },
        "top_headlines": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "url": { "type": ["string", "null"] },
              "why_it_matters": { "type": "string" }
            }
          }
        },
        "score_breakdown": {
          "type": "object",
          "description": "Echo of scores for UI; same shape as scores.*"
        },
        "trail": {
          "type": "object",
          "properties": {
            "engine": { "type": "string", "enum": ["k2", "fallback"] },
            "model": { "type": "string" },
            "prompt_version": { "type": "string" }
          }
        },
        "legacy": {
          "type": "object",
          "description": "Optional bridge: verdict/reasoning[] for current frontend",
          "properties": {
            "verdict": { "type": "string" },
            "reasoning": { "type": "array", "items": { "type": "string" } },
            "risk_factors": { "type": "array", "items": { "type": "string" } },
            "caveats": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "events": {
      "type": "array",
      "description": "Markers for timeline / charts on frontend",
      "items": {
        "type": "object",
        "required": ["id", "t", "kind", "label"],
        "properties": {
          "id": { "type": "string" },
          "t": { "type": "string", "format": "date-time" },
          "kind": {
            "type": "string",
            "enum": [
              "regulation",
              "election",
              "tariff",
              "antitrust",
              "executive",
              "sanctions",
              "macro",
              "controversy",
              "other"
            ]
          },
          "label": { "type": "string" },
          "severity_0_100": { "type": "number" },
          "source_headline_index": { "type": "integer" }
        }
      }
    },
    "prediction_stub": {
      "type": "object",
      "description": "Optional future Polymarket-style block; safe to omit",
      "properties": {
        "event_hypothesis": { "type": "string" },
        "implied_direction": {
          "type": "string",
          "enum": ["bullish", "bearish", "uncertain"]
        },
        "confidence_language": { "type": "string" }
      }
    },
    "meta": {
      "type": "object",
      "required": ["cached", "latency_ms", "sources"],
      "properties": {
        "cached": { "type": "boolean" },
        "latency_ms": { "type": "integer" },
        "sources": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "$defs": {
    "componentScore": {
      "type": "object",
      "required": ["score_0_100", "label", "rationale"],
      "properties": {
        "score_0_100": { "type": "number", "minimum": 0, "maximum": 100 },
        "label": { "type": "string" },
        "rationale": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "quality": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      }
    }
  }
}
