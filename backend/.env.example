# Optional: leave unset to use in-memory store + mock/demo data paths
MONGO_URI=
MONGO_DB_NAME=yhack_invest

# Financial data (one is enough; FMP tried first when both set)
FMP_API_KEY=
FINNHUB_API_KEY=

# News (optional; Finnhub company news used when FINNHUB_API_KEY is set)
NEWS_API_KEY=

# OpenAI-compatible endpoints for K2 / Hermes (direct to provider OR via Lava gateway)
# Lava: https://www.lava.so/ — use their base URL + key; same /chat/completions shape.
AI_K2_BASE_URL=
AI_K2_API_KEY=
AI_K2_MODEL=k2-think-v2

AI_HERMES_BASE_URL=
AI_HERMES_API_KEY=
AI_HERMES_MODEL=hermes

# Polymarket (when integrated) — see docs/API_KEYS.md and https://polymarket.com/settings?tab=builder
# POLYMARKET_API_KEY=

ANALYSIS_CACHE_TTL_MINUTES=45
HTTP_TIMEOUT_SECONDS=12
CORS_ORIGINS=http://localhost:3000

# Prepend curated JSON from data/news_snapshots/{TICKER}.json (set false to disable)
NEWS_SNAPSHOT_MERGE=true
